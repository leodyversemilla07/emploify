PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:***@localhost:5432/emploify?schema=public

BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=replace-with-strong-secret

# Optional ATS providers
GREENHOUSE_COMPANY_NAME=
LEVER_COMPANY_HANDLE=
LEVER_COMPANY_NAME=
ASHBY_JOBS_URL=
ASHBY_COMPANY_NAME=

# Optional social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Job sync
JOB_SYNC_ENABLED=false
JOB_SYNC_INTERVAL_MINUTES=60

# LLM provider (optional — heuristic fallback when not configured)
# LLM_PROVIDER: "openai-compat" (default) | "anthropic"
LLM_PROVIDER=openai-compat
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Examples for other providers:
#   OpenAI:     LLM_BASE_URL=https://api.openai.com/v1       LLM_MODEL=gpt-4o-mini
#   Azure:      LLM_BASE_URL=https://<resource>.openai.azure.com/openai  LLM_MODEL=gpt-4o
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.1-70b-versatile
#   Together:   LLM_BASE_URL=https://api.together.xyz/v1     LLM_MODEL=meta-llama/Llama-3-70b-chat-hf
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1    LLM_MODEL=meta-llama/llama-3-70b-instruct
#   Ollama:     LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=llama3.1
#   Anthropic:  LLM_PROVIDER=anthropic                        LLM_MODEL=claude-sonnet-4-20250514
